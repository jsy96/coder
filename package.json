{
  "name": "forge-code",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js && node --check app.js",
    "capabilities": "node server.js --capability-audit",
    "capabilities:json": "node server.js --capability-audit --json",
    "external-readiness": "node server.js --external-readiness",
    "external-readiness:json": "node server.js --external-readiness --json",
    "smoke": "node server.js --smoke-test",
    "port-smoke": "node server.js --port-conflict-smoke-test",
    "ui-smoke": "node server.js --ui-smoke-test",
    "api-smoke": "node server.js --api-smoke-test",
    "api-smoke:fast": "node server.js --api-smoke-section=fast",
    "api-smoke:coding": "node server.js --api-smoke-section=coding",
    "api-smoke:debug": "node server.js --api-smoke-section=debug",
    "api-smoke:integrations": "node server.js --api-smoke-section=integrations",
    "api-smoke:publish": "node server.js --api-smoke-section=publish"
  }
}
